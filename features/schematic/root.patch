+        // Headless Firefox runs at dpr=1; pcbnew's stricter `> 1` check assumes a
+        // Retina-aware run. The eeschema MVP just needs to verify dpr is sane.
+        expect(metrics.dpr).toBeGreaterThanOrEqual(1);
