+    }
+    if (y)
+    {
+        *y += origin.y;
+    }
+}
+
+void wxWindowWasm::DoScreenToClient(int *x, int *y) const
+{
+    wxPoint origin = GetScreenPositionOfClientOrigin(this);
+
+    if (x)
+    {
+        *x -= origin.x;
+    }
+    if (y)
+    {
+        *y -= origin.y;
+    }
+}
