+#define GET_JAVASCRIPT_STRING(varName, string) \
+  { \
+    int length = EM_ASM_INT({ \
+      return lengthBytesUTF8(varName); \
+    }); \
+    char* buffer = new char[length + 1]; \
+    EM_ASM({ \
+      stringToUTF8(varName, $0, $1); \
+    }, buffer, length + 1); \
+    string = buffer; \
+    delete [] buffer; \
+  }
