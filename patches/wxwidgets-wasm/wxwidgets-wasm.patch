+            stippleBitmap->SyncToJs();
+            bitmapId = stippleBitmap->GetJavascriptId();
+        }
+
+        EM_ASM({
+            setPen($0, $1, $2, $3, $4, $5, $6, $7);
+        }, GetJavascriptId(),
+           m_pen.GetColour().GetRGBA(),
+           m_pen.GetWidth(),
+           wxPenJoinToHTML5LineJoin(m_pen.GetJoin()),
+           wxPenCapToHTML5LineCap(m_pen.GetCap()),
+           m_pen.GetDashCount(),
+           m_pen.GetDash(),
+           bitmapId);
