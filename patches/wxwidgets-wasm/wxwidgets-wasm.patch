+wxWindow *wxApp::GetMouseWindow(const wxPoint& position) const
+{
+    wxWindow *captureWindow = wxWindow::GetCapture();
+    if (captureWindow != NULL)
+    {
+        return captureWindow;
+    }
+    else
+    {
+        return wxFindWindowAtPoint(position);
+    }
+}
